/* pages/privacy/privacy.wxss */
.page-privacy { padding: 0 32rpx 60rpx; }

.privacy-header {
  padding: 48rpx 0 32rpx;
  border-bottom: 1rpx solid var(--border-light);
  margin-bottom: 32rpx;
}
.privacy-title { font-size: 40rpx; font-weight: 700; display: block; }
.privacy-update { font-size: 24rpx; color: var(--text-tertiary); display: block; margin-top: 8rpx; }

.privacy-body { display: flex; flex-direction: column; gap: 32rpx; }
.privacy-section { display: flex; flex-direction: column; gap: 12rpx; }
.section-title { font-size: 30rpx; font-weight: 600; }
.section-text { font-size: 26rpx; color: var(--text-secondary); line-height: 1.8; padding-left: 16rpx; }