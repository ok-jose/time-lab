/* pages/add/add.wxss - 添加页样式 */

.page-add { padding-bottom: 60rpx; }

/* 模式选择网格 */
.mode-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  max-width: 100vw;
  box-sizing: border-box;
}
.mode-card {
  background: var(--surface-elevated);
  border-radius: var(--radius-lg);
  padding: 36rpx 24rpx;
  display: flex; flex-direction: column; align-items: center;
  gap: 16rpx;
  border: 2rpx solid var(--border-light);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.mode-card:active { transform: scale(0.96); }
.mode-card.selected {
  border-color: var(--accent);
  box-shadow: 0 0 0 6rpx var(--accent-light);
}
.mode-icon {
  width: 80rpx; height: 80rpx;
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
}
.ocr-bg { background: #e8e8f8; }
.scan-bg { background: #e0f0ec; }
.photo-bg { background: #f0e8f4; }
.manual-bg { background: #fdf4e0; }

.mode-label { font-size: 28rpx; font-weight: 600; }
.mode-desc { font-size: 20rpx; color: var(--text-tertiary); text-align: center; }

/* 操作卡片 */
.form-section { padding: 0 32rpx 24rpx; max-width: 100vw; box-sizing: border-box; }
.action-card {
  background: var(--surface-elevated);
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-md);
  padding: 48rpx;
  display: flex; flex-direction: column; align-items: center;
  gap: 20rpx;
  position: relative; overflow: hidden;
}
.action-card:active { background: #f8f7fc; }
.action-card-icon { font-size: 56rpx; }
.action-card-text { font-size: 28rpx; color: var(--accent); font-weight: 500; }

/* Loading 态（OCR 识别中 / 条码查询中） */
.action-card-loading {
  display: flex; align-items: center; gap: 12rpx;
  font-size: 28rpx; color: var(--accent);
}
.loading-dot {
  display: inline-block;
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: var(--accent);
  animation: loading-bounce 1.2s infinite ease-in-out;
}
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes loading-bounce {
  0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
  40% { transform: translateY(-8rpx); opacity: 1; }
}
.loading-text { font-weight: 500; }

/* 云端未配置提示 */
.cloud-tip {
  background: var(--warning-bg);
  border-left: 6rpx solid var(--warning);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  display: flex; flex-direction: column; gap: 6rpx;
  font-size: 26rpx; color: #8a6d0f;
}
.cloud-tip.success {
  background: #e8f6ee; color: #2d8a56;
  border-left-color: var(--safe);
}
.cloud-tip-sub {
  font-size: 22rpx; color: var(--text-tertiary);
}

/* OCR 解析出的字段 */
.ocr-fields-card {
  background: var(--surface-elevated);
  border-left: 6rpx solid var(--accent);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  display: flex; flex-direction: column; gap: 14rpx;
}
.ocr-field-row {
  display: flex; align-items: center; gap: 16rpx;
  font-size: 26rpx;
}
.ocr-field-label {
  color: var(--text-tertiary);
  font-size: 22rpx;
  text-transform: uppercase; letter-spacing: 1rpx;
  min-width: 120rpx; flex-shrink: 0;
}
.ocr-field-value {
  font-weight: 600;
  color: var(--text-primary);
  font-family: monospace;
}
.ocr-raw-text {
  white-space: pre-line;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  word-break: break-all;
}
.preview-thumb {
  width: 160rpx; height: 160rpx;
  border-radius: var(--radius-sm);
  margin-top: 16rpx;
}

/* OCR/扫码结果卡片 */
.ocr-result-card, .scan-result-card {
  background: var(--surface-elevated);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  border-left: 6rpx solid var(--accent);
}
.scan-barcode { font-size: 22rpx; color: var(--text-tertiary); font-family: monospace; display: block; }
.scan-product { font-size: 28rpx; display: block; margin-top: 8rpx; }
.scan-multiline { white-space: pre-line; line-height: 1.6; }

.ocr-fill-btn {
  margin-top: 16rpx;
  align-self: flex-start;
  padding: 12rpx 24rpx;
  background: var(--accent-light);
  color: var(--accent);
  border-radius: var(--radius-sm);
  font-size: 24rpx; font-weight: 600;
}

/* 表单区域 */
.form-area { padding: 0 32rpx; max-width: 100vw; box-sizing: border-box; }
.form-group {
  display: flex; flex-direction: column; gap: 16rpx;
  margin-bottom: 32rpx;
}
.form-label {
  font-size: 24rpx; font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase; letter-spacing: 2rpx;
}
.form-hint {
  font-size: 22rpx; color: var(--text-tertiary);
  line-height: 1.5;
}
.form-row { display: flex; gap: 16rpx; }
.flex-1 { flex: 1; }
.picker-field { color: var(--text-primary); }

/* 分类选择 */
.cat-select-row {
  display: flex; flex-wrap: wrap; gap: 16rpx;
}
.cat-chip {
  padding: 14rpx 24rpx;
  border-radius: 100rpx;
  border: 2rpx solid var(--border);
  font-size: 26rpx; color: var(--text-secondary);
  background: transparent;
}
.cat-chip.active {
  background: var(--text-primary);
  color: #ffffff;
  border-color: var(--text-primary);
}

/* 文本域 */
.textarea-field {
  min-height: 120rpx;
  padding: 24rpx 28rpx;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 20rpx;
  width: 100%;
  padding: 32rpx;
  background: var(--text-primary);
  color: #ffffff;
  border-radius: var(--radius-xl);
  font-size: 32rpx; font-weight: 600;
  text-align: center;
  border: none;
  letter-spacing: 2rpx;
}
.submit-btn:active { opacity: 0.85; transform: scale(0.97); }

/* 预设模板区 */
.template-section {
  padding: 16rpx 32rpx 24rpx;
  max-width: 100vw;
  box-sizing: border-box;
}
.template-scroll {
  white-space: nowrap;
  margin-top: 12rpx;
  max-width: 100%;
}
.template-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0 12rpx;
}
.template-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, var(--surface) 100%);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  min-width: 120rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.03);
}
.template-chip:active {
  border-color: var(--accent);
  background: var(--accent-light);
  transform: scale(0.96);
}
.template-icon { font-size: 36rpx; line-height: 1; }
.template-name { font-size: 24rpx; font-weight: 600; color: var(--text-primary); }
.template-days { font-size: 20rpx; color: var(--text-tertiary); }