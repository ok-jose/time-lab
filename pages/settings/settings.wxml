<!-- pages/settings/settings.wxml - 设置页 -->
<view class="page-settings">
  <!-- 云开发状态提示 -->
  <view class="cloud-status" wx:if="{{!cloudReady || !templateConfigured}}">
    <text class="cloud-status-title">⚙️ 提醒功能需要配置</text>
    <text class="cloud-status-line" wx:if="{{!cloudReady}}">· 未配置云开发 envId</text>
    <text class="cloud-status-line" wx:if="{{cloudReady && !templateConfigured}}">· 未配置订阅消息模板 ID</text>
    <text class="cloud-status-sub">详见 CLOUD_SETUP.md</text>
  </view>

  <view class="settings-section">
    <view class="settings-item" bindtap="toggleReminder">
      <text>过期提醒</text>
      <view class="reminder-right">
        <text wx:if="{{loading}}" class="reminder-loading">处理中…</text>
        <switch wx:else checked="{{reminderEnabled}}" disabled="{{loading}}" />
      </view>
    </view>
    <view class="settings-item" bindtap="toggleCloudSync">
      <text>云同步</text>
      <text class="icon-arrow">→</text>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-item" bindtap="exportData">
      <text>导出数据</text>
      <text class="icon-arrow">→</text>
    </view>
    <view class="settings-item" bindtap="showClearDialog">
      <text>清空所有数据</text>
      <text class="icon-arrow">→</text>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-item" bindtap="goPrivacy">
      <text>隐私政策</text>
      <text class="icon-arrow">→</text>
    </view>
    <view class="settings-item" bindtap="showAbout">
      <text>关于用不过期</text>
      <text class="icon-arrow">→</text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">用不过期 · 让生活更有条理</text>
  </view>

  <!-- 清空确认弹窗 -->
  <view wx:if="{{showClearConfirm}}" class="modal-overlay" bindtap="hideClearDialog">
    <view class="modal-content" catchtap="stopPropagation">
      <text class="modal-title">确认操作</text>
      <text class="modal-body">确定要清空所有物品数据吗？此操作不可恢复。</text>
      <view class="modal-actions">
        <view class="modal-btn cancel-btn" bindtap="hideClearDialog">取消</view>
        <view class="modal-btn confirm-btn" bindtap="clearAllData">确认清空</view>
      </view>
    </view>
  </view>
</view>
