/* pages/index/index.wxss - 首页样式 */

.page-index {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 自定义导航 */
.nav-bar { padding: 0 32rpx; }
.status-bar {
  padding: 20rpx 0 12rpx;
  display: flex; justify-content: flex-end;
}
.time-mono { font-size: 24rpx; color: var(--text-secondary); font-family: monospace; letter-spacing: 2rpx; }
.nav-header {
  display: flex; align-items: center; justify-content: space-between;
  padding-bottom: 16rpx;
}
.nav-title { font-size: 48rpx; font-weight: 700; letter-spacing: -1rpx; }
.nav-actions { display: flex; gap: 12rpx; }
.icon-btn {
  width: 72rpx; height: 72rpx;
  border-radius: var(--radius-sm);
  background: var(--surface-elevated);
  display: flex; align-items: center; justify-content: center;
}
.icon-text { font-size: 32rpx; }

/* 统计卡 */
.stats-card {
  margin: 0 32rpx 24rpx;
  padding: 28rpx 16rpx;
  background: var(--surface-elevated);
  border-radius: var(--radius-lg);
  display: flex; align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.stat-item {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; align-items: center;
  gap: 6rpx;
}
.stat-num {
  font-size: 40rpx; font-weight: 700;
  font-family: monospace;
  letter-spacing: 1rpx;
  line-height: 1.1;
}
.stat-item.safe .stat-num { color: var(--safe); }
.stat-item.warning .stat-num { color: var(--warning); }
.stat-item.danger .stat-num { color: var(--danger); }
.stat-label {
  font-size: 22rpx; color: var(--text-tertiary);
  letter-spacing: 1rpx;
}
.stat-divider {
  width: 1rpx; height: 56rpx;
  background: var(--border-light);
}

/* 搜索框 */
.search-bar {
  padding: 0 32rpx 16rpx;
  box-sizing: border-box;
}
.search-input-wrap {
  background: var(--surface-elevated);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  height: 80rpx;
  display: flex; align-items: center;
  gap: 16rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}
.search-input-wrap:focus-within { border-color: var(--accent); }
.search-icon { font-size: 28rpx; flex-shrink: 0; }
.search-input {
  flex: 1; min-width: 0;
  font-size: 28rpx;
  color: var(--text-primary);
  background: transparent;
  border: none;
  padding: 0;
}
.search-clear {
  font-size: 40rpx;
  color: var(--text-tertiary);
  line-height: 1;
  padding: 0 8rpx;
  flex-shrink: 0;
}

/* 排序 */
.sort-bar {
  padding: 8rpx 32rpx 20rpx;
  display: flex; align-items: center; gap: 16rpx;
}
.sort-label {
  font-size: 22rpx; color: var(--text-tertiary);
  text-transform: uppercase; letter-spacing: 2rpx;
  flex-shrink: 0;
}
.sort-options {
  display: flex; gap: 12rpx; flex: 1; overflow-x: auto;
}
.sort-chip {
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  background: transparent;
  font-size: 24rpx; color: var(--text-secondary);
  border: 2rpx solid var(--border);
  flex-shrink: 0;
}
.sort-chip.active {
  background: var(--accent-light);
  color: var(--accent);
  border-color: var(--accent-light);
  font-weight: 600;
}

/* 提醒横幅 */
.alert-banner {
  margin: 0 32rpx 24rpx;
  padding: 24rpx 32rpx;
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: space-between;
  font-size: 28rpx; font-weight: 500;
}
.alert-banner.all-safe { background: #e8f6ee; color: #2d8a56; }
.alert-banner.warning { background: var(--warning-bg); color: #8a6d0f; }
.alert-banner.danger { background: var(--danger-bg); color: #a82d2d; }
.alert-badge {
  font-size: 32rpx; font-weight: 700;
  padding: 8rpx 20rpx; border-radius: 40rpx;
}
.alert-banner.warning .alert-badge { background: rgba(212,160,23,0.2); }
.alert-banner.danger .alert-badge { background: rgba(217,69,53,0.2); }
.safe-badge { background: rgba(61,173,110,0.2); }

/* 分类标签 */
.cat-tabs {
  padding: 0 32rpx 24rpx;
  white-space: nowrap;
}
.cat-tabs-inner {
  display: flex;
  gap: 12rpx;
  width: max-content;
}
.cat-tab {
  display: inline-flex;
  padding: 16rpx 28rpx;
  border-radius: 100rpx;
  border: 2rpx solid var(--border);
  font-size: 26rpx; font-weight: 500;
  color: var(--text-secondary);
  background: transparent;
  flex-shrink: 0;
}
.cat-tab.active {
  background: var(--text-primary);
  color: #ffffff;
  border-color: var(--text-primary);
}

/* 物品列表 */
.items-scroll { min-height: 400rpx; overflow-x: hidden; }
.items-section {
  padding: 0 32rpx;
  display: flex; flex-direction: column; gap: 16rpx;
  max-width: 100vw;
  box-sizing: border-box;
}
.item-card {
  background: var(--surface-elevated);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  display: flex; align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.item-card:active { transform: scale(0.98); opacity: 0.9; }

.item-icon {
  width: 96rpx; height: 96rpx;
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.item-icon.safe { background: var(--safe-bg); }
.item-icon.warning { background: var(--warning-bg); }
.item-icon.danger { background: var(--danger-bg); }
.item-icon.used { background: var(--used-bg); }
.item-emoji { font-size: 44rpx; }

.item-info {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 4rpx;
}
.item-name {
  font-size: 30rpx; font-weight: 600;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.item-meta {
  font-size: 22rpx; color: var(--text-tertiary);
  font-family: monospace; letter-spacing: 1rpx;
}

.item-status-area {
  display: flex; flex-direction: column; align-items: flex-end;
  gap: 8rpx; flex-shrink: 0;
}
.status-dot {
  width: 18rpx; height: 18rpx; border-radius: 50%;
}
.status-dot.safe { background: var(--safe); }
.status-dot.warning { background: var(--warning); }
.status-dot.danger { background: var(--danger); }
.status-dot.used { background: var(--used); }

.days-text { font-size: 24rpx; font-weight: 600; }
.days-text.safe { color: var(--safe); }
.days-text.warning { color: #8a6d0f; }
.days-text.danger { color: #a82d2d; }
.days-text.used { color: var(--used); }

.bottom-spacer { height: 40rpx; }

/* 悬浮添加按钮 */
.fab-btn {
  position: fixed;
  right: 48rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.2);
  z-index: 99;
}
.fab-btn:active {
  transform: scale(0.92);
  opacity: 0.85;
}
.fab-icon {
  font-size: 60rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}
