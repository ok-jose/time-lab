/* pages/calendar/calendar.wxss */

.page-calendar {
  padding: 24rpx 32rpx 60rpx;
  max-width: 100vw;
  box-sizing: border-box;
}

/* ===== 月份切换 ===== */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--surface-elevated);
  border-radius: var(--radius-lg);
  padding: 24rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.month-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--text-secondary);
  font-weight: 300;
}
.month-btn:active { background: var(--accent-light); color: var(--accent); }
.month-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: -apple-system, monospace;
}

/* ===== 图例 ===== */
.legend {
  display: flex;
  gap: 24rpx;
  padding: 0 8rpx 20rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}
.legend-dot.danger { background: var(--danger); }
.legend-dot.warning { background: var(--warning); }

/* ===== 星期表头 ===== */
.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.weekday {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  padding: 8rpx 0;
  font-weight: 500;
}
.weekday.weekend { color: var(--accent); }

/* ===== 日期网格 ===== */
.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}
.day-cell {
  aspect-ratio: 1 / 1;
  background: var(--surface-elevated);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  position: relative;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.day-cell.empty {
  background: transparent;
  box-shadow: none;
}
.day-cell.past:not(.empty) {
  background: var(--danger-bg);
}
.day-cell.today {
  border-color: var(--accent);
  background: var(--accent-light);
}
.day-cell.selected {
  border-color: var(--accent);
  box-shadow: 0 0 0 4rpx var(--accent-light);
}
.day-cell:active:not(.empty) {
  transform: scale(0.95);
}
.day-num {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  font-family: -apple-system, monospace;
}
.day-cell.past .day-num { color: var(--danger); font-weight: 600; }
.day-cell.today .day-num { color: var(--accent); font-weight: 700; }

.day-badge {
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
  min-width: 28rpx;
  text-align: center;
  line-height: 1.2;
  font-family: monospace;
}
.day-badge.danger { background: var(--danger); }
.day-badge.warning { background: var(--warning); }

/* ===== 当日详情 ===== */
.day-detail {
  margin-top: 28rpx;
  background: var(--surface-elevated);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.day-detail-empty {
  margin-top: 28rpx;
  background: var(--surface-elevated);
  border-radius: var(--radius-lg);
  padding: 48rpx 24rpx;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.detail-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-family: -apple-system, monospace;
}
.detail-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-top: 2rpx solid var(--border-light);
}
.detail-item:first-of-type { border-top: none; }
.detail-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}
.detail-icon.safe { background: var(--safe-bg); }
.detail-icon.warning { background: var(--warning-bg); }
.detail-icon.danger { background: var(--danger-bg); }
.detail-icon.used { background: var(--used-bg); }
.detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.detail-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.detail-meta {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.detail-status {
  font-size: 22rpx;
  font-weight: 600;
  font-family: monospace;
  flex-shrink: 0;
}
.detail-status.safe { color: var(--safe); }
.detail-status.warning { color: var(--warning); }
.detail-status.danger { color: var(--danger); }
.detail-status.used { color: var(--used); }

/* ===== 月汇总 ===== */
.month-summary {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: var(--surface-elevated);
  border-radius: var(--radius-lg);
  padding: 28rpx 16rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.ms-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.ms-num {
  font-size: 40rpx;
  font-weight: 700;
  font-family: -apple-system, monospace;
  color: var(--text-primary);
  line-height: 1.1;
}
.ms-item:nth-child(1) .ms-num { color: var(--danger); }
.ms-item:nth-child(3) .ms-num { color: var(--accent); }
.ms-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.ms-divider {
  width: 2rpx;
  height: 56rpx;
  background: var(--border);
}